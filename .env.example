# .env 파일 작성 예시

# Database (PostgreSQL)
POSTGRES_URL=jdbc:postgresql://localhost:5432/monew
POSTGRES_USER_NAME=admin
POSTGRES_PASSWORD=0000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/monew

# AWS S3 (백업용)
AWS_ACCESS_KEY=your_access_key
AWS_SECRET_KEY=your_secret_key
AWS_REGION=ap-northeast-2
S3_BUCKET_NAME=monew-backup